//rtd_outl(0x1800786C, 0x33333333);  //IB1: mc1:mc2=1:1 scramble, slice=1024 bytes
//rtd_outl(0x18007894, 0x00000000);  //IB2

 //case 3: mc1:mc2:mc3:mc4=1:1:1:1
 rtd_outl(0x18007844, 0x33333333);  //IB0: IB1:IB2=1:1 scramble, slice=1024 bytes
 rtd_outl(0x1800786C, 0x33333333);  //IB1: mc1:mc2=1:1 scramble, slice=1024 bytes
 rtd_outl(0x18007894, 0x33333333);  //IB2: mc3:mc4=1:1 scramble, slice=1024 bytes 

