//=====[CTS_FIFO_DC1]=====//
rtd_maskl(0x180c9060, 0xffff9cff, 0x00006300); //[14:13]=1,[9:8]=1: mck_cs = cmd pi
rtd_maskl(0x180c9000, 0xca02a780, 0x008c0044); //[2]=1:2to1 mode, set pin_mux mode=lpddr4,  set tx/rx cts_fifo_cnt, remove cke_a0 and cke_b0 fw force, [1:0]=2b00:LPD4
rtd_maskl(0x180c905c, 0xfffcff00, 0x00000000); // remove cs_a0/cs_a1 and cs_b0/cs_b1 fw force

//=====[DCC_DCD_DC1]=====//
rtd_maskl(0x180c90a4, 0x48e08088, 0x15053834); //cs0 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c90a8, 0x48e08088, 0x15053834); //cs1 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c90b8, 0x48e08088, 0x15053834); //cs2 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c90bc, 0x48e08088, 0x15053834); //cs3 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c9030, 0x48e08088, 0x15053834); //cmd close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c9034, 0xc8e08088, 0x15053834); //dqs0 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c9038, 0xc8e08088, 0x15053834); //dqs1 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c903c, 0xc8e08088, 0x15053834); //dqs2 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c9040, 0xc8e08088, 0x15053834); //dqs3 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c9044, 0xc8e08088, 0x15053834); //dq0~7 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c9048, 0xc8e08088, 0x15053834); //dq8~15 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c904c, 0xc8e08088, 0x15053834); //dq16~23 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c9050, 0xc8e08088, 0x15053834); //dq24~31 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c9054, 0xc8e08088, 0x15053834); //ck0 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c9058, 0xc8e08088, 0x15053834); //ck1 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c9104, 0xc8e08088, 0x15053834); //wck0 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c9108, 0xc8e08088, 0x15053834); //wck1 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c910c, 0xc8e08088, 0x15053834); //wck2 close loop mode[29]=0,preset[6:4][2:0]
rtd_maskl(0x180c9110, 0xc8e08088, 0x15053834); //wck3 close loop mode[29]=0,preset[6:4][2:0]

//=====[PLL_INITIAL_VALUE_DC1]=====//
//postpi power
rtd_maskl(0x180c908c, 0xfffffffe, 0x00000001); //[0]pll_ldo_rst_n=1,release pll ldo reset
ScalerTimer_DelayXms(5);
rtd_maskl(0x180c9008, 0x7fffffff, 0x80000000); //dpi_ldo_pow[31]=0:AVDD,=1:postPI LDO
ScalerTimer_DelayXms(80);
//ck tree power,dpi_ck_pwr_sel[14:11]
rtd_maskl(0x180c900c, 0x0ff0ff00, 0x70080000); //[31:28]=7:post PI bias, dpi_ldo_pow_ck[19]=1:LDO power on ,ldo_sel0:core power, 1:0.8V/2:0.85V/3:0.9V/4:0.95V/5:1.05V/6:1.1V/7:1.15V
ScalerTimer_DelayXms(80);
rtd_maskl(0x180c90d4, 0xffff07ff, 0x00000000); //[15:11]=0:select LDO for CK tree, ck tree DVDD open
//4266Mbps
rtd_maskl(0x180c9018, 0x00380008, 0x04405875); //PLL initial setting, [31:29]=3b000, postpi=LDO tracking AVDD (0.9V),[21:19]=?

//=====[CRT_INITIAL_FLOW_DC1]=====//
rtd_maskl(0x180c908c, 0xfffffffe, 0x00000001); //[0]pll_ldo_rst_n=1,release pll ldo reset
ScalerTimer_DelayXms(80);
rtd_maskl(0x180c908c, 0xfffffffd, 0x00000002); //[1]:pll_ssc_dig_rst_n=1,release reset PLL SSC circuit
ScalerTimer_DelayXms(80);
rtd_maskl(0x180c9008, 0xffff7fff, 0x00008000); //[31]mck_mc_en(for controller)
rtd_maskl(0x180c9090, 0x7fffffcf, 0x80000000); //[31] lpddr5 wck always on, [5:4]: rw_blk clock is always on
rtd_maskl(0x180c908c, 0xfffffff7, 0x00000000); //[3]:ptr_rst_n=0
rtd_maskl(0x180c908c, 0xfffffff3, 0x0000000c); //[3]:ptr_rst_n=1,[2]:rst_n=1
ScalerTimer_DelayXms(80);
rtd_maskl(0x180c9028, 0xfbffffff, 0x04000000); //[26]dpi_oc_en=1
rtd_maskl(0x180c9028, 0xfbffffff, 0x00000000); //[26]dpi_oc_en=0
rtd_maskl(0x180c901c, 0xfffffff7, 0x00000008); //[3]dpi_ssc_flag_init=1
rtd_maskl(0x180c901c, 0xfffffffd, 0x00000002); //[2]=1:enable ssc

rtd_maskl(0x180c90d8, 0xfe00fe00, 0x00120012); //CK1_dly[24:16],CK0_dly[8:0]
rtd_maskl(0x180c90d8, 0x7fff7fff, 0x80008000); //CK0/CK1 tree update                                                                            

rtd_maskl(0x180c9004, 0xffff0000, 0x0000ffff);
rtd_maskl(0x180c9008, 0xfffbffff, 0x00040000); //set dpi_clk_oe[18]=1, mck_ck1
ScalerTimer_DelayXms(80);
rtd_maskl(0x180c9008, 0xfffdffff, 0x00020000); //set dpi_clk_oe[17]=1, mck_cmd/mck_dq/mck_dqs/mck_cs/mck_cs2
ScalerTimer_DelayXms(80);
rtd_maskl(0x180c9008, 0xfffeffff, 0x00010000); //set dpi_clk_oe[16]=1, mck_ck

//=====[DPI_DLL_DC1]=====//
rtd_maskl(0x180c9310, 0xefffffff, 0x10000000); //[28]=1,set_reg_valid automatically
rtd_maskl(0x180c9310, 0xffc0ffff, 0x001a0000); //rd_update_dly[21:16]=0x1a @2:1mode
rtd_maskl(0x180c9310, 0xffff80ff, 0x00003000); //rd_update_dly_rx[14:8]=0x30
rtd_maskl(0x180c9308, 0xffc1c0c0, 0x003e2000); //data_pre[21]=1,data_init[20]=1:lpddr5,ref_update_dly[13:8]=0x20, cal_dqsen_mode=disable
rtd_maskl(0x180c9308, 0xefff7fff, 0x10008000); //rd_pre_2t=1, wr_pre_2t=1
rtd_maskl(0x180c9254, 0xff7fffff, 0x00800000); //[23]=1:LPDDR4 DQS postamble 1.5 T
rtd_maskl(0x180c9308, 0xfffffffc, 0x00000002); //2t_wr_pre[28]=1, 2t_rd_pre[15]=0 , fw_set delay[1:0]=2 immediately update

//=====[PAD_BYPASSMODE]=====//
rtd_maskl(0x180c928c, 0xffff0000, 0x0000ff55); //bit[1] : DQS BYPASSMODE =1 , RX VD18 power savibng disable, bit[0] : DQ BYPASSMODE =1 , RX VD18 power savibng disable

//=====[PAD_ZQ_CALIBRATION]=====//
// 50% VDD cal
rtd_maskl(0x180c9240, 0xffffc0fe, 0x00000000); //zq_ena_nocd2[0]=0 disable NOCD2 for 0.5VDD
rtd_maskl(0x180c92f4, 0x7ffffffc, 0x80000002); //en_dcc[31]=1, rx_ibias_sel[17:16]=2
rtd_maskl(0x180c9234, 0xffff500e, 0x00008080); //rzq_ext_R240[15]=1,zq_vref_pd[13]=0,zq_vref_s_ini[10:4]=0x08(50%)
rtd_maskl(0x180c9308, 0xfffffffc, 0x00000002); //fw_set delay[1:0]=2 immediately update
rtd_maskl(0x180c9234, 0xfffeeffb, 0x00010000); //zq_vref_sel_ini[16]=1,zq_en_dmyi[12]=0,zq_vref_range_ini[2]=0
rtd_maskl(0x180c92f8, 0xfffffcff, 0x00000000); //[9]=0: PD of CK1 PAD, [8]=0: PD of CK0 PAD
rtd_maskl(0x180c9230, 0x00080080, 0x0c008c19); //[27]=1:zq auto update,[26:25]=2'b10:zclk/32,[19]=1:R240 external,zq_cal_cmd[7]=1
rtd_maskl(0x180c930c, 0x00000000, 0x00000003); //update write delay tap
ScalerTimer_DelayXms(80);
//zq cal. for SET0
rtd_maskl(0x180c9230, 0x8fffffff, 0x00000000); //Enable auto update OCD/ODT set0
rtd_maskl(0x180c95c8, 0xf8c0f8c0, 0x00240024); //OCD=40, ODT=40
rtd_maskl(0x180c95e8, 0xfffff8c0, 0x00000000); //nocd2_zprog=0
rtd_maskl(0x180c9230, 0xfeffffff, 0x01000000); //Calibration Start
ScalerTimer_DelayXms(80);
rtd_maskl(0x180c9230, 0xfeffffff, 0x00000000); //Disable Calibration
//zq cal. for SET1
rtd_maskl(0x180c9230, 0x8fffffff, 0x10000000); //Enable auto update OCD/ODT set1
rtd_maskl(0x180c95cc, 0xf8c0f8c0, 0x001d001d); //OCD=50, ODT=50
rtd_maskl(0x180c95e8, 0xf8c0ffff, 0x00000000); //nocd2_zprog=0
rtd_maskl(0x180c9230, 0xfeffffff, 0x01000000); //Calibration Start
ScalerTimer_DelayXms(80);
rtd_maskl(0x180c9230, 0xfeffffff, 0x00000000); //Disable Calibration
//zq cal. for SET2
rtd_maskl(0x180c9230, 0x8fffffff, 0x20000000); //Enable auto update OCD/ODT set2
rtd_maskl(0x180c95d0, 0xf8c0f8c0, 0x00180018); //OCD=60, ODT=60
rtd_maskl(0x180c95ec, 0xfffff8c0, 0x00000000); //nocd2_zprog=0
rtd_maskl(0x180c9230, 0xfeffffff, 0x01000000); //Calibration Start
