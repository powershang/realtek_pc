rtd_maskl(0x180c9014, 0xe0e0e0e0, 0x00061e05); //DQ0[20:16],DQS3[12:8],DQS2[4:0]
rtd_maskl(0x180c9098, 0xe0e0e0e0, 0x00030603); //CS0[28:24],DQ3[20:16],DQ2[12:8],DQ1[4:0]
rtd_maskl(0x180c90a0, 0xe0e0e0e0, 0x05000000); //CK1[28:24],CS3[20:16],CS2[12:8],CS1[4:0]
rtd_maskl(0x180c90f0, 0xe0e0e0e0, 0x00000000); //WCK3[28:24],WCK2[20:16],WCK1[12:8],WCK0[4:0]
rtd_maskl(0x180c9008, 0xffff8000, 0x00000028); //oesync:CK1[14],CS3~0[13:10],DQ3~0[9:6],DQS3~0[5:2],CMD[1],CK0[0]
