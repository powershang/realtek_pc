//=====[AFIFO_DC1]=====//
rtd_maskl(0x180c9080, 0x00000000, 0x46564656); //txdqfifo:DQS3/DQ3/DQS2/DQ2/DQS1/DQ1/DQS0/DQ0
rtd_maskl(0x180c9088, 0xffff0000, 0x00004444); //rxdqfifo:DQ3/DQ2/DQ1/DQ0 rxdqfifo+1=tm_dqsen-2
rtd_maskl(0x180c90f8, 0xffff0000, 0x0000aaaa); //wck_afifo:WCK3/WCK2/WCK1/WCK0
rtd_maskl(0x180c9084, 0xffffff00, 0x00000044); //txcmdfifo:ex_rd_str_num[6:4],rd_str_num[2:0]
rtd_maskl(0x180c90e0, 0x00000000, 0x00000000); //txcmdfifo_sel_m[31:0]:1=ex_rd_str_num, 0=rd_str_num
rtd_maskl(0x180c90e4, 0x00000000, 0x00000000); //txcmdfifo_sel_h[31:0]:1=ex_rd_str_num, 0=rd_str_num
rtd_maskl(0x180c9094, 0x00000000, 0x00000000); //txcmdfifo_sel[31:0]:1=ex_rd_str_num,0=rd_str_num

//pok update step1: dc1
