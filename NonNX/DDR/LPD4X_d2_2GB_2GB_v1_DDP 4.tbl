//-------- PLL NNIP, 760.45M-------------------------------------------------
//Fout=Fref*((NCODE+4)+(FCODE/2048))/(PREDIV+1)/(2^O)
rtd_outl(0x180004BC,0x00010019);	//[30:28]PLLNNIP_O=0,[24]BPSPI=0(through PI),[21]PLLNNIP_WDSET=0,[20]PLLNNIP_WDRST=0
									//[14]CP=b'0,[10:8]ICP=b'000,[3:0]RS=b'1001,[5:4]PLLNNIP_Prediv=0x1
rtd_outl(0x180004C0,0x00000004);	//PLLNNIP pll power down
rtd_outl(0x180004C0,0x02A33405);	//PLLNNIP pll power on,F=675,N=52,760.45MHz, set 27*((N+4)+(F/2048))/(prediv+1)/1=760.45MHz
rtd_outl(0x180004C4,0x50200805);	//Low Speed mode,oc_step=0x80,EN_PI_DEBUG=1,OC_EN=1,PI_CUR_SEL=0x0
ScalerTimer_DelayXms(0x1);							//at least > 100us
rtd_outl(0x180004C0,0x02A33407);	//release PLLNNIP reset
ScalerTimer_DelayXms(0x1);							//at least > 100us
rtd_outl(0x180004C0,0x02A33403);	//PLLNNIP output enable

//DRM
rtd_inl(0x18038880);	//0x18038880=0x69C35AC6
// rtd_outl(0x18038884,0x00000000);	//DRM password word1
// rtd_outl(0x18038888,0x00000000);	//DRM password word2
// rtd_outl(0x1803888c,0x00000000);	//DRM password word3
// rtd_outl(0x18038890,0x00000000);	//DRM password word4
rtd_outl(0x18038820,0x00000003);	//CRC_EN
ScalerTimer_DelayXms(0x200);
rtd_inl(0x18038894);	//[2]=1:done
rtd_maskl(0x18038894,0xfffffffe,0x00000001);	//password compare
rtd_inl(0x18038894);	//=0x6:password correct

//LG PCB enable DDR power supply
//POWER_ON/OFF1 ; +1.0V_DDR_SOC , DDR_0.6V , +1.2V_DDR_SOC(PIF)
rtd_part_outl(0x18060204,31,28, 0xF);  //set ST_GPIO4 pinmux to GPIO
rtd_part_outl(0x18061100,5,5, 0x1);    //set ST_GPIO4 to GPO
rtd_part_outl(0x18061108,5,5, 0x1);    //set ST_GPIO4 to high
//POWER_ON/OFF2_4 ; +1.8V_DDR    +1.1V_DDR_SoC
rtd_part_outl(0x18060208,31,28, 0xF);  //set ST_GPIO8 pinmux to GPIO
rtd_part_outl(0x18061100,9,9, 0x1);    //set ST_GPIO8 to GPO
rtd_part_outl(0x18061108,9,9, 0x1);    //set ST_GPIO8 to high

// ** Pre_CRT ** //
//LPD4X/LPD5 4MC
rtd_outl(0x18000104, 0x02000001);  //[25]RSTN_DCPHY1
rtd_outl(0x18000114, 0x02000001);  //[25]CLKEN_DCPHY1

rtd_outl(0x1800010c, 0x02000001);  //[25]RSTN_DCPHY2
rtd_outl(0x1800011c, 0x02000001);  //[25]CLKEN_DCPHY2

rtd_outl(0x1800010c, 0x00800001);  //[23]RSTN_DC_MC1
rtd_outl(0x18000124, 0x00000021);  //[5]RSTN_DC_MC2
rtd_outl(0x18000120, 0x01000001);  //[24]RSTN_DC_MC3
rtd_outl(0x18000124, 0x00000081);  //[7]RSTN_DC_MC4

rtd_outl(0x1800011c, 0x04000001);  //[26]CLKEN_DC_MC1_MCK
rtd_outl(0x18000134, 0x00000041);  //[6]CLKEN_DC_MC2_MCK
rtd_outl(0x18000130, 0x02000001);  //[25]CLKEN_DC_MC3_MCK
rtd_outl(0x18000134, 0x00000101);  //[8]CLKEN_DC_MC4_MCK

rtd_outl(0x1800011c, 0x00800001);  //[23]CLKEN_DC_MC1
rtd_outl(0x18000134, 0x00000021);  //[5]CLKEN_DC_MC2
rtd_outl(0x18000130, 0x01000001);  //[24]CLKEN_DC_MC3
rtd_outl(0x18000134, 0x00000081);  //[7]CLKEN_DC_MC4

rtd_outl(0x18000100, 0x00040001);  //[18]RSTN_DC_MC_EXP
rtd_outl(0x18000124, 0x00010001);  //[16]Rstn_dcmc_exp2
rtd_outl(0x18000124, 0x00020001);  //[17]RSTN_dcmc_exp3

rtd_outl(0x18000110, 0x00040001);  //[18]CLKEN_DC_MC_EXP
rtd_outl(0x18000134, 0x00010001);  //[16]CLKEN_dcmc_exp2
rtd_outl(0x18000134, 0x00020001);  //[17]CLKEN_dcmc_exp3

//LPD4X
rtd_outl(0x18000134, 0x3c000001);  //[29:26]CLKEN_dc_mc4_lp4,CLKEN_dc_mc3_lp4,CLKEN_dc_mc2_lp4,CLKEN_dc_mc1_lp4
rtd_outl(0x18000134, 0x20000001);  //Clken_dc_mc1_lp4
rtd_outl(0x18000134, 0x10000001);  //Clken_dc_mc2_lp4
rtd_outl(0x18000134, 0x08000001);  //Clken_dc_mc3_lp4
rtd_outl(0x18000134, 0x04000001);  //Clken_dc_mc4_lp4

// //LPD5
// rtd_outl(0x18000138, 0xf0000001);  //[31:28]CLKEN_dc_mc4_lp5,CLKEN_dc_mc3_lp5,CLKEN_dc_mc2_lp5,CLKEN_dc_mc1_lp5
// rtd_outl(0x18000138, 0x10000001);  //CLKEN_dc_mc1_lp5
// rtd_outl(0x18000138, 0x20000001);  //CLKEN_dc_mc2_lp5
// rtd_outl(0x18000138, 0x40000001);  //CLKEN_dc_mc3_lp5
// rtd_outl(0x18000138, 0x80000001);  //CLKEN_dc_mc4_lp5

// rtd_outl(0x18007600, 0x00000000);  //no register
// rtd_outl(0x18007030, 0x40000000);  //[31:30]wdone_fifo_margin=01:fifo_depth > 22

rtd_outl(0x18007004, 0x61000200);

//rtd_outl(0x18007008, 0x00000000);  //LPD4X_1rank,[25:24]=2b00:8bank/1rank, [9:8]=2b00:8bank/1rank
rtd_outl(0x18007008, 0x02000200);  //LPD4X_2rank,[25:24]=2b00:8bank/2rank, [9:8]=2b00:8bank/2rank
// rtd_outl(0x18007008, 0x01000100);  //LPD5_1rank,[25:24]=2b00:16bank/1rank, [9:8]=2b00:16bank/1rank
// rtd_outl(0x18007008, 0x03000300);  //LPD5_2rank,[25:24]=2b00:16bank/2rank, [9:8]=2b00:16bank/2rank

//IB
rtd_maskl(0x18007004,0xbfffffff,0x00000000);  //[30]:dcib_8_region_en=0, 4_region

// //case 1: all mc1
//rtd_outl(0x18007844, 0x03030303);  //IB0: all IB1, slice=1024 bytes
//rtd_outl(0x1800786C, 0x03030303);  //IB1: all mc1, slice=1024 bytes
//rtd_outl(0x18007894, 0x00000000);  //IB2
 
//////case 2: mc1:mc2=1:1, mc3/mc4 NULL
